# ── Polymarket (Polygon wallet) ───────────────────────────────────────────────
# Export private key from MetaMask: Account → ... → Account Details → Export Private Key
POLY_PRIVATE_KEY=0x...your_private_key_here...

# Generate ONCE after setting POLY_PRIVATE_KEY:
#   python polymarket_bot.py --setup
POLY_API_KEY=
POLY_API_SECRET=
POLY_API_PASSPHRASE=

# ── Betting limits ────────────────────────────────────────────────────────────
MAX_STAKE_USDC=1.0
MIN_CONFIDENCE=0.68

# ── Arbitrage sources (all have free tiers) ───────────────────────────────────
# The Odds API — https://the-odds-api.com  (free: 500 req/month, no CC)
ODDS_API_KEY=

# BetsAPI — https://betsapi.com  ($1 trial, then $29/mo — real-time in-play)
BETSAPI_TOKEN=

# OddsPapi — https://oddspapi.io  (free: 250 req/month, 350+ bookmakers)
ODDSPAPI_KEY=

# ── Arb bot settings ─────────────────────────────────────────────────────────
ARB_BANK_USD=50.0
MIN_PROFIT_PCT=0.5

# ── India local mode (routes API calls through Brave browser) ─────────────────
# Set to 1 when running LOCALLY in India (Polymarket is DNS-blocked)
# Set to 0 (or leave blank) for Railway deployment
USE_BRAVE=0
